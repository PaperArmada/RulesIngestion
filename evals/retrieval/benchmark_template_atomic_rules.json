{
  "metadata": {
    "batch_id": "TEMPLATE",
    "created_by": "template",
    "pdf_source": "<FILL_ME>",
    "creation_method": "atomic_rules_template",
    "created_at": "YYYY-MM-DD",
    "notes": "Template for atomic-rules retrieval benchmarks. Duplicate this file, fill metadata fields, then fill per-query expectations + gold anchors for the target ruleset.",
    "schema_version": "retrieval_benchmark_v1",
    "schema": {
      "top_level_keys": [
        "metadata",
        "queries"
      ],
      "metadata_fields": {
        "batch_id": "string (human-friendly identifier, e.g. 'atomic_001')",
        "created_by": "string (human|agent|pipeline name)",
        "pdf_source": "string (source document name, e.g. 'PZO22003_PlayerCore.pdf')",
        "creation_method": "string (how this benchmark was created)",
        "created_at": "string (YYYY-MM-DD)",
        "notes": "string (freeform)",
        "schema_version": "string",
        "schema": "object (this schema description; optional in non-template benchmarks)"
      },
      "query_fields": {
        "id": "string (stable id; do not change once published)",
        "tier": "string (e.g. 'T1', 'T2', 'T3')",
        "question_type": "string (e.g. 'atomic_rules', 'lookup', 'reasoning')",
        "question": "string (the query prompt)",
        "answer": "string (full verbose answer; can be empty for new benchmarks)",
        "expected_answer_summary": "string (short, target-ruleset-specific expectation; can be empty for new benchmarks)",
        "source_page": "string|null (comma-separated page numbers in the source PDF, if known)",
        "notes": "string (what this is testing, edge cases, ambiguity notes)",
        "refusal_acceptable": "boolean (optional; true if 'cannot find rule' is acceptable)",
        "scoring_rubric": "string (optional; scoring notes for evaluators)",
        "gold_unit_ids": "string[] (merged union of required_gold + supporting_gold; populated by grounding)",
        "gold_locations": "object (unit_id -> {page, structural_path, source_unit_ids}; populated by grounding)",
        "required_gold": "string[] (unit ids that MUST be retrieved for a correct answer)",
        "supporting_gold": "string[] (unit ids that help but aren't strictly required)",
        "required_gold_rationale": "object (unit_id -> string explaining why it's required)",
        "_mode": "string ('single_cite' | 'multi_cite'; default 'single_cite')",
        "_status": "string ('pending' | 'cited'; annotation status)",
        "_required_gold": "string[] (internal; normalized required_gold used by metrics)",
        "_supporting_gold": "string[] (internal; normalized supporting_gold used by metrics)"
      }
    }
  },
